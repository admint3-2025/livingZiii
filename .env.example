# ZIII Living — Environment Configuration

# ======== DATABASE ========
# sqlite = desarrollo local sin Docker | postgres = producción/staging
DATABASE_TYPE=sqlite
DATABASE_PATH=apps/backend/data/ziii_living_dev.sqlite

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=ziii_user
DATABASE_PASSWORD=ziii_password_dev
DATABASE_NAME=ziii_living_dev

CORS_ORIGIN=http://localhost:5173

# ======== SEED (desarrollo) ========
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password

# ======== API ========
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000

# ======== JWT ========
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRATION=7d

# ======== PAYMENT PROVIDERS ========
# Mercado Pago
MERCADO_PAGO_PUBLIC_KEY=TEST-your-mp-key
MERCADO_PAGO_SECRET_KEY=TEST-your-mp-secret

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# ======== ACCESS CONTROL INTEGRATIONS ========
# Hikvision
HIKVISION_API_HOST=192.168.1.100
HIKVISION_API_PORT=443
HIKVISION_USERNAME=admin
HIKVISION_PASSWORD=admin123
HIKVISION_PROTOCOL=https
HIKVISION_ALLOW_INSECURE_TLS=true
HIKVISION_INTEGRATION_MODE=device
HIKVISION_TEAM_ACCOUNT=
HIKVISION_TEAM_ID=
HIKVISION_TEAM_AUTH_TOKEN=
HIKVISION_TEAM_SESSION_COOKIE=
HIKVISION_OPENAPI_BASE_URL=
HIKVISION_TOKEN_ENDPOINT=/api/hccgw/platform/v1/token/get
HIKVISION_APP_KEY=
HIKVISION_APP_SECRET=
HIKVISION_SITE_ID=
HIKVISION_COMMUNITY_ID=
HIKVISION_BUILDING_ID=
HIKVISION_ROOM_ID=
# Comma-separated Hik-Connect Teams access level IDs (alIds) required for a usable temp pass
HIKVISION_DEFAULT_ACCESS_GROUP_ID=
HIKVISION_VEHICULAR_ACCESS_GROUP_ID=
HIKVISION_PEDESTRIAN_ACCESS_GROUP_ID=
HIKVISION_VISITOR_QR_ENDPOINT=/api/hccgw/vims/v1/tempauth/add
HIKVISION_VISITOR_GET_ENDPOINT=/api/hccgw/vims/v1/tempauth/get
HIKVISION_VISITOR_LIST_ENDPOINT=/api/hccgw/vims/v1/tempauth/list
HIKVISION_VISITOR_REVOKE_ENDPOINT=/api/hccgw/vims/v1/tempauth/delete

# Dahua
DAHUA_API_HOST=192.168.1.101
DAHUA_API_PORT=80
DAHUA_USERNAME=admin
DAHUA_PASSWORD=admin123

# ======== EMAIL (Transactional) ========
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ======== LOGGING ========
LOG_LEVEL=debug

# ======== AWS (Optional — future S3 for documents) ========
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
